# Copy to `.env` and fill in. `.env` is gitignored — never commit or paste into issues.
#
# Load before wrangler (PowerShell):
#   . .\scripts\use-env.ps1
#
# Or set manually:
#   $env:CLOUDFLARE_API_TOKEN = "..."

# --- Cloudflare account (wrangler deploy / whoami) ---
# CLOUDFLARE_API_TOKEN must include (Account-level):
#   - Workers Scripts: Edit   (required — Pages-only token will fail deploy with code 10000)
#   - Workers KV Storage: Edit (read OG_INDEX; often already on P34.3 token)
# Optional: Account Settings Read, User Details Read (helps wrangler whoami)
# P18.6 Pages-only token is NOT enough for npm run deploy.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- OG_INDEX KV (SSOT — wrangler.toml id/preview_id sync from this before deploy) ---
# Same namespace as main-repo P34.3. Run: npm run sync-wrangler
OG_INDEX_KV_NAMESPACE_ID=

# Optional: dedicated KV-only token; if empty, wrangler/main sync uses CLOUDFLARE_API_TOKEN
# OG_INDEX_KV_API_TOKEN=
