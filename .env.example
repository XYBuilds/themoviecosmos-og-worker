# Copy to `.env` and fill in. `.env` is gitignored — never commit or paste into issues.
#
# Load before wrangler (PowerShell):
#   . .\scripts\use-env.ps1
#
# Or set manually:
#   $env:CLOUDFLARE_API_TOKEN = "..."

# --- Cloudflare account (wrangler deploy / whoami) ---
# Token needs: Workers Scripts Edit (deploy this Worker).
# Same token as main-repo Pages deploy is OK if it includes Workers permissions.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- OG_INDEX KV (must match wrangler.toml [[kv_namespaces]] id) ---
# Same namespace as main-repo P34.3 (OG_INDEX_KV_NAMESPACE_ID).
OG_INDEX_KV_NAMESPACE_ID=

# Optional: dedicated KV-only token; if empty, wrangler/main sync uses CLOUDFLARE_API_TOKEN
# OG_INDEX_KV_API_TOKEN=
